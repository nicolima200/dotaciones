rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función auxiliar: verifica si el usuario inició sesión
    function isAuthenticated() {
      return request.auth != null;
    }

    // Función auxiliar para obtener el rol del usuario actual
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Función auxiliar para verificar si es admin
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }

    // Función auxiliar: verifica si el usuario tiene un rol asignado y válido
    function hasValidRole() {
      let userRole = getUserRole();
      return userRole == 'admin' || 
             userRole == 'turno1' || 
             userRole == 'turno2' || 
             userRole == 'turno3' || 
             userRole == 'turno4';
    }

    // 1. Reglas para la colección 'users' (Manejo de Roles)
    match /users/{userId} {
      // LEER: El propio usuario puede leer sus datos, y el admin puede leer a todos
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // PERMITIR CREAR: Solo si el usuario está logueado, es su propio ID y se asigna a sí mismo el rol "pending"
      allow create: if isAuthenticated() 
                    && request.auth.uid == userId 
                    && request.resource.data.role == 'pending';
      
      // ACTUALIZAR/BORRAR: Solo el administrador puede modificar roles o borrar usuarios
      allow update, delete: if isAdmin(); 
    }

    // 2. Reglas para la colección 'audit_logs' (Auditoría de Acciones)
    match /audit_logs/{logId} {
      allow create: if isAuthenticated() && hasValidRole();
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // 3. Reglas para las nuevas colecciones
    match /agents/{agentId} {
      allow read: if isAuthenticated() && hasValidRole();
      
      // Permitir crear solo si es admin o si el agente pertenece al mismo turno del usuario
      allow create: if isAuthenticated() && hasValidRole() && (
        isAdmin() || 
        (getUserRole() == 'turno1' && request.resource.data.turno == 1) ||
        (getUserRole() == 'turno2' && request.resource.data.turno == 2) ||
        (getUserRole() == 'turno3' && request.resource.data.turno == 3) ||
        (getUserRole() == 'turno4' && request.resource.data.turno == 4)
      );
      
      // Permitir actualizar solo si es admin o si el agente original pertenece al mismo turno del usuario
      allow update: if isAuthenticated() && hasValidRole() && (
        isAdmin() || 
        (getUserRole() == 'turno1' && resource.data.turno == 1) ||
        (getUserRole() == 'turno2' && resource.data.turno == 2) ||
        (getUserRole() == 'turno3' && resource.data.turno == 3) ||
        (getUserRole() == 'turno4' && resource.data.turno == 4)
      );
      
      // Permitir eliminar solo si es admin o si el agente pertenece al mismo turno del usuario
      allow delete: if isAuthenticated() && hasValidRole() && (
        isAdmin() || 
        (getUserRole() == 'turno1' && resource.data.turno == 1) ||
        (getUserRole() == 'turno2' && resource.data.turno == 2) ||
        (getUserRole() == 'turno3' && resource.data.turno == 3) ||
        (getUserRole() == 'turno4' && resource.data.turno == 4)
      );
    }

    // 4. Reglas para la colección 'schedules'
    match /schedules/{scheduleId} {
      allow read: if isAuthenticated() && hasValidRole();
      
      // Permitir crear solo si es admin o si el schedule creado pertenece al mismo turno del usuario
      allow create: if isAuthenticated() && hasValidRole() && (
        isAdmin() || 
        (getUserRole() == 'turno1' && request.resource.data.shift == 'turno1') ||
        (getUserRole() == 'turno2' && request.resource.data.shift == 'turno2') ||
        (getUserRole() == 'turno3' && request.resource.data.shift == 'turno3') ||
        (getUserRole() == 'turno4' && request.resource.data.shift == 'turno4')
      );
      
      // Permitir actualizar solo si es admin o si el original y el nuevo dato pertenecen al mismo turno del usuario
      allow update: if isAuthenticated() && hasValidRole() && (
        isAdmin() || 
        (
          ((getUserRole() == 'turno1' && resource.data.shift == 'turno1') ||
           (getUserRole() == 'turno2' && resource.data.shift == 'turno2') ||
           (getUserRole() == 'turno3' && resource.data.shift == 'turno3') ||
           (getUserRole() == 'turno4' && resource.data.shift == 'turno4')) &&
          ((getUserRole() == 'turno1' && request.resource.data.shift == 'turno1') ||
           (getUserRole() == 'turno2' && request.resource.data.shift == 'turno2') ||
           (getUserRole() == 'turno3' && request.resource.data.shift == 'turno3') ||
           (getUserRole() == 'turno4' && request.resource.data.shift == 'turno4'))
        )
      );
      
      // Permitir eliminar solo si es admin o si el schedule pertenece al mismo turno del usuario
      allow delete: if isAuthenticated() && hasValidRole() && (
        isAdmin() || 
        (getUserRole() == 'turno1' && resource.data.shift == 'turno1') ||
        (getUserRole() == 'turno2' && resource.data.shift == 'turno2') ||
        (getUserRole() == 'turno3' && resource.data.shift == 'turno3') ||
        (getUserRole() == 'turno4' && resource.data.shift == 'turno4')
      );
    }

    match /infrastructure/{document=**} {
      allow read: if isAuthenticated() && hasValidRole();
      
      // Permitir crear solo si es admin o si la infra pertenece al mismo turno del usuario
      allow create: if isAuthenticated() && hasValidRole() && (
        isAdmin() || 
        (getUserRole() == 'turno1' && request.resource.data.turno == 1) ||
        (getUserRole() == 'turno2' && request.resource.data.turno == 2) ||
        (getUserRole() == 'turno3' && request.resource.data.turno == 3) ||
        (getUserRole() == 'turno4' && request.resource.data.turno == 4)
      );
      
      // Permitir actualizar solo si es admin o si la infra original y el nuevo dato pertenecen al mismo turno del usuario
      allow update: if isAuthenticated() && hasValidRole() && (
        isAdmin() || 
        (
          ((getUserRole() == 'turno1' && resource.data.turno == 1) ||
           (getUserRole() == 'turno2' && resource.data.turno == 2) ||
           (getUserRole() == 'turno3' && resource.data.turno == 3) ||
           (getUserRole() == 'turno4' && resource.data.turno == 4)) &&
          ((getUserRole() == 'turno1' && request.resource.data.turno == 1) ||
           (getUserRole() == 'turno2' && request.resource.data.turno == 2) ||
           (getUserRole() == 'turno3' && request.resource.data.turno == 3) ||
           (getUserRole() == 'turno4' && request.resource.data.turno == 4))
        )
      );
      
      // Permitir eliminar solo si es admin o si la infra pertenece al mismo turno del usuario
      allow delete: if isAuthenticated() && hasValidRole() && (
        isAdmin() || 
        (getUserRole() == 'turno1' && resource.data.turno == 1) ||
        (getUserRole() == 'turno2' && resource.data.turno == 2) ||
        (getUserRole() == 'turno3' && resource.data.turno == 3) ||
        (getUserRole() == 'turno4' && resource.data.turno == 4)
      );
    }
  }
}
